APP_PORT=8084
APP_NAME=billing-service
APP_ENV=local
LOG_LEVEL=info
LOG_FORMAT=json

POSTGRES_DSN=postgres://<user>:<password>@localhost:5432/parkir_pintar?sslmode=disable

NATS_URL=nats://localhost:4222

# gRPC address of the Payment Service (no scheme)
PAYMENT_SERVICE_URL=localhost:8086

# OpenTelemetry — leave empty to disable
OTEL_SERVICE_NAME=parkirpintar-billing
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_METRIC_EXPORT_INTERVAL=60
OTEL_BLRP_SCHEDULE_DELAY=60
